#!/bin/bash

# Find the physical directory where this hook script is located
FILE_PATH="$0"
while [ -L "$FILE_PATH" ]; do
    FILE_DIR=$(cd -P "$(dirname "$FILE_PATH")" && pwd)
    FILE_PATH=$(readlink "$FILE_PATH")
    [[ $FILE_PATH != /* ]] && FILE_PATH="$FILE_DIR/$FILE_PATH"
done
HOOK_REAL_DIR=$(cd -P "$(dirname "$FILE_PATH")" && pwd)

# Target script in the sibling directory
SCRIPT_PATH="$(dirname "$HOOK_REAL_DIR")/scripts/ai_review.sh"

if [ ! -f "$SCRIPT_PATH" ]; then
    echo "❌ Error: AI review script not found at $SCRIPT_PATH"
    exit 1
fi

bash "$SCRIPT_PATH" --non-interactive
