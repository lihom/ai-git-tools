# AI Git Tools Configuration
# Copy this file to .env in your project root

# Choose your AI engine: gemini, ollama, codex
AI_ENGINE=gemini

# Engine-specific models
GEMINI_MODEL=gemini-3-flash-preview
OLLAMA_MODEL=gemma3
CODEX_MODEL=gpt-4o

# Customizable Prompt Paths (Relative to the ai-git-tools repository, or absolute paths)
# REVIEW_PROMPT_PATH=./.agent/skills/git-ai-assistant/resources/prompts/review-style-gemini-github.md
# COMMIT_PROMPT_PATH=./.agent/skills/git-ai-assistant/resources/prompts/commit-style-commitlint.md
